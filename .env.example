# Commerce AI Core - Environment Variables Example
# Copy this file to .env and fill in your values

# ============================================
# General Configuration
# ============================================
ENVIRONMENT=development
APP_NAME=commerce-ai-core
LOG_LEVEL=INFO
PYTHON_VERSION=3.12

# ============================================
# Database Configuration
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=commerce_ai_core
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ============================================
# Temporal Configuration
# ============================================
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=commerce-ai-core-tasks

# ============================================
# Qdrant Configuration
# ============================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_URL=http://${QDRANT_HOST}:${QDRANT_PORT}

# ============================================
# MinIO/S3 Configuration
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadminpassword
MINIO_BUCKET=commerce-ai-core
MINIO_USE_SSL=false

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# ============================================
# JWT & Security
# ============================================
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# ============================================
# Frontend Configuration
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Commerce AI Core

# ============================================
# AI/LLM Configuration
# ============================================
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================
# Integrations - Shopify
# ============================================
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers

# ============================================
# Integrations - Zoho CRM
# ============================================
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://localhost:8000/integrations/zoho/callback
ZOHO_REGION=US  # or EU, IN, AU

# ============================================
# Integrations - WhatsApp
# ============================================
WHATSAPP_CLOUD_API_TOKEN=your_whatsapp_cloud_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# ============================================
# Observability
# ============================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=commerce-ai-core
SENTRY_DSN=your_sentry_dsn_here

# ============================================
# Feature Flags
# ============================================
ENABLE_AI_DECISIONS=true
ENABLE_HUMAN_APPROVAL=true
ENABLE_AUTO_SEND=false
