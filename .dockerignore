# Commerce AI Core - .dockerignore
# يمنع نسخ الملفات غير الضرورية إلى داخل صور Docker

# ============================================
# Git
# ============================================
.git
.gitignore

# ============================================
# Documentation
# ============================================
docs/
*.md
!requirements/

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ============================================
# Virtual environments
# ============================================
venv/
env/
ENV/
.venv

# ============================================
# IDE
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================
# Testing
# ============================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ============================================
# Logs
# ============================================
*.log
logs/

# ============================================
# Environment files (will be mounted)
# ============================================
.env
.env.local
.env.*.local

# ============================================
# Node.js
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# Next.js
# ============================================
.next/
out/

# ============================================
# TypeScript
# ============================================
*.tsbuildinfo

# ============================================
# Docker Compose overrides
# ============================================
docker-compose.override.yml
docker-compose.prod.yml

# ============================================
# OS
# ============================================
.DS_Store
Thumbs.db

# ============================================
# Temporary files
# ============================================
tmp/
temp/
*.tmp
*.bak

# ============================================
# Test files (optional - include in production)
# ============================================
tests/
*_test.py
test_*.py

# ============================================
# Development scripts
# ============================================
scripts/

# ============================================
# Infrastructure data directories
# ============================================
minio_data/
postgres_data/
redis_data/
qdrant_storage/
temporal_data/

# ============================================
# Terraform & Kubernetes configs
# ============================================
infra/kubernetes/
infra/terraform/
*.tfstate
*.tfstate.backup
.terraform/

# ============================================
# Secrets
# ============================================
secrets/
credentials/
*.pem
*.key

# ============================================
# Local overrides
# ============================================
local/
overrides/
